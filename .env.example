# Local runtime profile
WNA_ENV=local
WNA_USER_AGENT=WoningAlertNL/0.1 (+contact-email)
WNA_CONTACT_EMAIL=
WNA_REQUEST_TIMEOUT_SECONDS=20
WNA_MAX_REQUESTS_PER_RUN=100
WNA_MAX_REQUESTS_PER_DOMAIN=10
WNA_MIN_REQUEST_INTERVAL_SECONDS=2
WNA_RESPECT_ROBOTS_TX=true
WNA_ENABLE_PLAYWRIGHT=false

# LLM settings
LLM_PROVIDER=openai
# OPENAI_API_KEY goes only in local .env, never in git.
OPENAI_API_KEY=
LLM_MODEL=
# ENABLE_LLM_EXTRACTION stays false by default.
ENABLE_LLM_EXTRACTION=false
# MAX_LLM_CALLS_PER_RUN stays 0 by default to avoid accidental cost.
MAX_LLM_CALLS_PER_RUN=0
MAX_LLM_TOKENS_PER_RUN=0

# Storage
WNA_STORAGE_BACKEND=sqlite
WNA_SQLITE_PATH=data/local/woningalert.sqlite

# Playwright remains false by default because it is not the MVP path.
